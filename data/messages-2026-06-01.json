      "plant": "L1",
      "web_url": "https://teams.microsoft.com/l/chat/19%3A17cdef05e40440a6a7d64757067ca624%40thread.v2/0?tenantId=46913ced-e190-4f33-b3f3-2a38ddf9cac4",
