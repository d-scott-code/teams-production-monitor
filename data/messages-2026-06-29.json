          "web_url": null
        },
        {
          "id": "1782735909222",
          "from": "Itzel Chavez",
          "from_upn": null,
          "sent_utc": "2026-06-29T12:25:09.222Z",
          "sent_mt": "2026-06-29T06:25:09-06:00",
